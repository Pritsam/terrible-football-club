# ─── Supabase ──────────────────────────────────────────────────────────────────
# Local dev: run `supabase start` then copy the "API URL" and "anon key" values.
# Production: copy from your hosted project's Settings > API page.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Site URL ──────────────────────────────────────────────────────────────────
# Used to build absolute URLs (e.g. OAuth redirect, invite links).
# Local dev: http://localhost:3000
# Production: your Vercel deployment URL, e.g. https://terrible-fc.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ─── Google OAuth (optional) ───────────────────────────────────────────────────
# Required only if you want "Continue with Google" to work.
# 1. Create OAuth 2.0 credentials in Google Cloud Console.
# 2. Add the client ID + secret here AND in Supabase Auth > Providers > Google.
# 3. Set the authorised redirect URI to:
#    https://<your-supabase-project>.supabase.co/auth/v1/callback
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
