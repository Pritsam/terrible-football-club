# Supabase project (from `supabase status` once `supabase start` is running locally,
# or from your hosted project's API settings)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Base URL used to build the OAuth redirect (falls back to the request host if unset)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google OAuth credentials for Supabase Auth's Google provider.
# Create these in Google Cloud Console, then set them here and in your
# hosted project's Auth > Providers settings (local config reads these too).
SUPABASE_AUTH_EXTERNAL_GOOGLE_CLIENT_ID=
SUPABASE_AUTH_EXTERNAL_GOOGLE_SECRET=
